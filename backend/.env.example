APP_NAME=BioGate AI
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://biogate:biogate@postgres:5432/biogate
JWT_SECRET_KEY=change-me-in-production-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
POSTGRES_DB=biogate
POSTGRES_USER=biogate
POSTGRES_PASSWORD=biogate
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
